{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch(*)",
      "Write",
      "Edit",
      "Bash(date*)",
      "Bash(python3*)",
      "Bash(curl*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(echo*)",
      "Bash(npx*)",
      "Bash(rm*)",
      "Bash(mkdir*)",
      "Bash(mv*)",
      "Bash(cp*)"
    ],
    "deny": [
      "Bash(sudo*)",
      "Bash(systemctl*)",
      "Bash(chmod*)",
      "Bash(chown*)",
      "Read(./.env)"
    ]
  }
}
